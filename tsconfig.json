{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2015",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "outDir": "./",
    "rootDir": "./",
    "sourceMap": true,
    "lib": ["ES2017", "DOM", "DOM.Iterable"]
  },
  "include": ["main.ts"],
  "exclude": ["node_modules"]
}
